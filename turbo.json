{
    "$schema": "https://turborepo.org/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "dev:home": {
            "cache": false
        },
        "lint": {
            "cache": false
        },
        "lint:code": {
            "cache": false
        },
        "lint:format": {
            "cache": false
        },
        "lintfix": {
            "cache": false
        },
        "lintfix:code": {
            "cache": false
        },
        "lintfix:format": {
            "cache": false
        }
    }
}
