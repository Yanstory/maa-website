{
    "name": "maa-website",
    "version": "1.0.0",
    "description": "MAA website project",
    "type": "module",
    "repository": "https://github.com/MaaAssistantArknights/maa-website",
    "license": "AGPL-3.0-or-later",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build && node bundler.js",
        "lint": "pnpm run lint:format && pnpm run lint:code",
        "lint:code": "turbo run lint:code",
        "lint:format": "prettier --check .",
        "lintfix": "pnpm run lintfix:format && pnpm run lintfix:code",
        "lintfix:code": "turbo run lintfix",
        "lintfix:format": "prettier --write --list-different ."
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "prettier": "^3.6.2",
        "turbo": "^2.6.0"
    },
    "packageManager": "pnpm@10.20.0"
}
